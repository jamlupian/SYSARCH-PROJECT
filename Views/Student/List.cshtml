@model IEnumerable<CCSMonitoringSystem.Models.Student>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">

<div class="container mt-4">
    <h3>Registered Students</h3>
    <a class="btn btn-secondary mb-3" href="/Student/Index">Back to Login</a>

    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>IdNumber</th>
                <th>LastName</th>
                <th>FirstName</th>
                <th>Email</th>
                <th>Course</th>
                <th>CourseLevel</th>
                <th>Address</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in Model)
            {
                <tr>
                    <td>@s.IdNumber</td>
                    <td>@s.LastName</td>
                    <td>@s.FirstName</td>
                    <td>@s.Email</td>
                    <td>@s.Course</td>
                    <td>@s.CourseLevel</td>
                    <td>@s.Address</td>
                </tr>
            }
        </tbody>
    </table>
</div>